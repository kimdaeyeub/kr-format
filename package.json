{
  "name": "kr-format",
  "version": "1.0.0",
  "description": "한국 특화 포맷터 유틸리티 라이브러리",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "korea",
    "formatter",
    "phone",
    "money",
    "mask",
    "korean"
  ],
  "author": "kimdaeyeub",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/kimdaeyeub/kr-format.git"
  },
  "homepage": "https://github.com/kimdaeyeub/kr-format#readme",
  "bugs": {
    "url": "https://github.com/kimdaeyeub/kr-format/issues"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
